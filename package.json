{
  "name": "docmaker",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "fl": "prettier --write . && eslint . --fix",
    "m": "tsx ./scripts/manage-messages.js",
    "mw": "tsx ./scripts/manage-messages.js --write && prettier --write ./messages"
  },
  "devDependencies": {
    "@eslint/compat": "latest",
    "@eslint/js": "latest",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@inlang/paraglide-js": "^2.20.2",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "phosphor-svelte": "^3.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-compression2": "^2.5.3"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/sora": "^5.2.8",
    "@lucide/svelte": "^1.23.0",
    "@myriaddreamin/typst-ts-renderer": "0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "0.7.0-rc2",
    "@myriaddreamin/typst.ts": "0.7.0-rc2",
    "@vercel/analytics": "^2.0.1",
    "fflate": "^0.8.3",
    "mode-watcher": "^1.1.0"
  },
  "packageManager": "pnpm@11.10.0"
}
